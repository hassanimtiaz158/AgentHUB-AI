# ── Server ──────────────────────────────────────────────────────────────────
# Render sets PORT automatically; for local dev the default is 8000.
PORT=8000

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API.
# For local dev the defaults (localhost:3000/3001) are fine.
# For production, set this to your Vercel URL, e.g.:
#   CORS_ORIGINS=https://agenthub-ai.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# ── AI providers ───────────────────────────────────────────────────────────
# If unset, the analyzer falls back to a local rule-based engine that
# always responds — the app never crashes on a missing key.
# The router tries providers in order: Groq → OpenAI → local fallback.
OPENAI_API_KEY=
GROQ_API_KEY=
AI_API_KEY=

# ── Aicoo coordination layer ──────────────────────────────────────────────
# If unset, Aicoo endpoints run in deterministic mock mode (offline).
# Set to your Aicoo API key for real routing via https://www.aicoo.io
AICOO_API_KEY=

# ── Supabase (future) ─────────────────────────────────────────────────────
# The storage layer is currently in-memory. When you're ready to swap in
# Supabase, fill these and update app/database.py.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Database (future) ─────────────────────────────────────────────────────
DATABASE_URL=
